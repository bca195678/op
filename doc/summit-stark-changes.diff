+        self.opdiag_toml = toml.load(Board_INFO().opdiag_toml())['opdiag']
+        self.linux_prompt = re.compile(self.opdiag_toml['linux_prompt']).pattern
+        self.cli_prompt = re.compile(self.opdiag_toml['cli_prompt']).pattern
+        self.verbose_log_path_from_toml = self.opdiag_toml.get('verbose_log_path')
+        self.flow_log_path_from_toml = self.opdiag_toml.get('flow_log_path')
+
+        # Cli
+        try:
+            self.child = pexpect.spawn(
+                '/alpha/bin/cli', logfile=open(self.verbose_log_path_from_toml, 'wb')
+            )
+        except pexpect.exceptions.ExceptionPexpect as err_msg:
+            if self.verbose:
+                print(f'****{"*"*len(str(err_msg))}****')
+                print(f'*** {err_msg} ***')
+                print(f'****{"*"*len(str(err_msg))}****')
+            sys.exit(1)
+        except FileNotFoundError:
+            if self.verbose:
+                print('***********************************************************')
+                print('*** The provided path for the verbose log is incorrect. ***')
+                print('***********************************************************')
