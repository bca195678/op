+# ** It is a development feature **
+#
+# boot param: opdiag_linuxsh
+#
+# Raise Linux shell after boot.
+#
+export OPDIAG_LINUXSH=
+
+# OPDIAG_STOP_IF_FAIL
+#
+# ** It is a development feature **
+#
+# boot param: opdiag_stop_if_fail
+#
+# Once test item fails, stop testing and raise a shell.
+#
+export OPDIAG_STOP_IF_FAIL=
+
+# OPDIAG_MODE
+#
+# boot param: opdiag_mode=<mode>
+#   <mode>:
+#       normal: normal mode
+#       extended: extended mode (longer test time)
+#
+# Choose the test mode of operational diagnostics.
+#
+export OPDIAG_MODE=
+
+# OPDIAG_DIAGPART
+#
+# boot param: diagnostics_partition=<path to block device>
+#
+# For summit-stark, it should point to the partition for storing test result and
+# "internal flash" test. If this option is not provided, test result will not be
+# stored and "internal flash" test will do nothing and reports FAIL.
+#
+export OPDIAG_DIAGPART=
+
+verbose()
+{
+    if [ -n "${OPDIAG_VERBOSE}" ]; then
+        printf "\e[1;33m[VERBOSE] $@\n\e[0m"
+    fi
+}
+
+do_reboot()
+{
+    verbose "$0: Rebooting"
+
+    if [ -n "${OPDIAG_NO_REBOOT}" ]; then
+        echo "*** 'opdiag_no_reboot' detected, switch to Linux shell"
+        run_linuxsh
+    fi
+
+    # Suppress output.
+    if [ ! -n "${OPDIAG_VERBOSE}" ]; then
+        exec >/dev/null
+        exec 2>/dev/null
+    fi
+
+    # Umount diagnostics partition.
+    /alpha/bin/diagpart umount
+
+    # Stop RC services.
+    /etc/init.d/rcK
+
+    # Fallback reboot, it should not be executed.
+    sleep 3; reboot
+}
+
+# For summit-stark, the console is /dev/ttyS0,115200
+init_console()
+{
+    verbose "$0: Initialize console"
+
+    # Setup console port
+    # Baud => 115200
+    # Backup configuration
+    # Cancel "echo" to prevent odd display
+    stty -F /dev/ttyS0 115200
+    console_default="`stty -g -F /dev/ttyS0`"
+    stty -F /dev/ttyS0 -echo
+
+    exec >/dev/ttyS0
+    exec 2>/dev/null
+}
+
+fake_test()
+{
+    printf "%-29s" "$1"
+    sleep $2
+    if [ "$((RANDOM % 10))" == "1" ]; then
+        printf "FAIL\n"
+    else
+        printf "PASS\n"
+    fi
+}
+
+fake_opdiag()
+{
+    verbose "$0: Start"
+    echo "*****************************************************************"
+    echo "* Only for Early development                                    *"
+    echo "* Below test items are fake and do nothing. Test result is set  *"
+    echo "* randomly                                                      *"
+    echo "*****************************************************************"
+
+    if [ "${OPDIAG_MODE}" == "extended" ]; then
+        local mode_string="Extended mode"
+    elif [ "${OPDIAG_MODE}" == "normal" ]; then
+        local mode_string="Normal mode"
+    else
+        local mode_string="Unknown mode"
+    fi
+    echo "Initializing operational diagnostics..."
+    echo "Version ${RELEASE_VERSION}, ${RELEASE_DATE}"
+    echo
+    echo "Running Power On Self Test...(${mode_string})"
+    if [ "${OPDIAG_MODE}" != "normal" -a "${OPDIAG_MODE}" != "extended" ]; then
+        echo "The diagnostics mode is invalid, the system will reboot!"
+        return 1
+    fi
+    echo
+
+    fake_test "i2c environment" 1
+    fake_test "internal flash" 1
+    fake_test "memory" 1
+    fake_test "loopback mac interface" 1
+    fake_test "loopback phy copper" 1
+    fake_test "loopback phy fiber" 1
+    fake_test "snake interface" 1
+    fake_test "PoE" 1
+    fake_test "asic0 reg" 1
+    fake_test "asic0 mem" 1
+
+    echo
+    echo "Storing diagnostics result."
+    echo "Diagnostics completed."
+    echo "Waiting for reboot..."
+    verbose "$0: End"
+}
+
+parse_opdiag_opt()
+{
+    set -- $(cat /proc/cmdline)
+    for x in "$@"; do
+        case "$x" in
+            # Normal option
+            opdiag_mode=*)
+                OPDIAG_MODE="${x#opdiag_mode=}"
+                ;;
+            diagnostics_partition=*)
+                OPDIAG_DIAGPART="${x#diagnostics_partition=}"
+                ;;
+            # Development/Debug option
+            opdiag_debug_for_internal_use)
+                OPDIAG_VERBOSE=1
+                OPDIAG_DEV=1
+                ;;
+            # # Comment - Only for internal debug use.
+            # opdiag_linuxsh)
+            #     OPDIAG_LINUXSH=1
+            #     OPDIAG_DEV=1
+            #     touch /tmp/OPDIAG
+            #     ;;
+            # opdiag_stop_if_fail)
+            #     OPDIAG_STOP_IF_FAIL=1
+            #     OPDIAG_DEV=1
+            #     ;;
+            # opdiag_no_reboot)
+            #     OPDIAG_NO_REBOOT=1
+            #     OPDIAG_DEV=1
+            #     ;;
+            *)
+                ;;
+        esac
+    done
+}
+
+run_opdiag()
+{
+    verbose "$0: Start"
+
+    local extra_option=""
+
+    [ -n "${OPDIAG_STOP_IF_FAIL}" ] && extra_option="${extra_option} --stop-if-fail"
+    [ -n "${OPDIAG_NO_REBOOT}" ] && extra_option="${extra_option} --no-exit"
+    [ -n "${OPDIAG_VERBOSE}" ] && extra_option="${extra_option} --verbose"
+
+    /alpha/bin/opdiag \
+        --mode="${OPDIAG_MODE}" \
+        --release-version="${RELEASE_VERSION}" \
+        --release-date="${RELEASE_DATE}" \
+        ${extra_option}
+
+    verbose "$0: End"
+}
+
+run_linuxsh()
+{
+    init_console
+
+    stty -F /dev/ttyS0 "${console_default}"
+    stty -F /dev/ttyS0 echo
+
+    exec </dev/ttyS0
+    exec >/dev/ttyS0
+    exec 2>/dev/ttyS0
+
+    exec /bin/bash -l
+}
+
+################################################################################
+# Prepare and run
+################################################################################
+
+parse_opdiag_opt
+
+if [ -e /tmp/OPDIAG ]; then
+    # # Comment - Only for internal debug use.
+    # verbose "/tmp/OPDIAG detected, skipped"
+    return 0
+else
+    touch /tmp/OPDIAG
+fi
+
+if [ ! -e /etc/RELEASE.diag ]; then
+    verbose "Fatal error! /etc/RELEASE.diag is not found!"
+    return 1
+fi
+
+source /etc/RELEASE.diag
+
+init_console
+
+if [ -n "${OPDIAG_DEV}" ]; then
+    echo "*****************************************************************"
+    echo "*** DEVELOPMENT MODE, BEHAVIOR MIGHT DIFFER THAN FORMAL USAGE ***"
+    echo "***         THIS MODE IS ONLY FOR INTERNAL DEBUG USE          ***"
+    echo "*****************************************************************"
+    echo "`printenv`"
+    echo "*****************************************************************"
+    echo "`cat /proc/cmdline`"
+    echo "*****************************************************************"
+    echo "`mount`"
+    echo "*****************************************************************"
+    echo "`uname -a`"
+    echo "*****************************************************************"
+    exec 2>&1
+    /alpha/bin/alphach --register
+fi
+
+
+if [ -n "${OPDIAG_LINUXSH}" ]; then
+    echo "*** 'opdiag_linuxsh' detected, switch to Linux shell"
+    echo "*** Run '/alpha/bin/opdiag --help' to know how to run Operational Diagnostics manually"
+    run_linuxsh
+fi
+
+# Clear console screen.
+clear
+
+# Run test.
+#fake_opdiag
+run_opdiag
+
+# Ends, reboot.
+do_reboot
