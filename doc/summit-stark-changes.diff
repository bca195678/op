+    def dut_init(self):
+        '''
+        - DUT Init
+            quickstart
+            show interface status
+            show gearbox interface status
+        '''
+
+        init_error_pattern = r'\[\w+ \(\w+\.\w+:\d+\)\] Error: .+\n'
+        self.send_command('quickstart', 'End of Quickstart script', timeout=90)
+        self.child.expect('! ------------------------------------------------')
+        self.child.expect(self.cli_prompt)
+
+        # Check MAC Init Status
+        self.send_command('show interface status', self.cli_prompt)
+        mac_init_result = self.pexpect_output('before')
+        mac_init_fail = re.findall(init_error_pattern, mac_init_result)
+
+        # Init is finished
+        if not mac_init_fail:
+            self.mac_init = True
+
+        # Check Gearbox Init Status (only for boards with gearbox hardware)
+        if 'gearbox_toml' in Board_INFO()._board_info:
+            self.send_command('show gearbox interface status', self.cli_prompt)
+            gearbox_init_result = self.pexpect_output('before')
+            gearbox_init_fail = re.findall(init_error_pattern, gearbox_init_result)
+            if not gearbox_init_fail:
+                self.gearbox_init = True
+        else:
+            self.gearbox_init = True  # No gearbox on this board
+        if (not self.mac_init or not self.gearbox_init) and self.stop_if_fail:
+            self.interact()
+
+    def interact(self):
+        print('Raise the debug interactive session. Use "enter" to activate it and "ctrl-]" to return it')
+        if self.verbose:
+            self.child.logfile_read = None
+            self.child.interact()
+            self.child.logfile_read = sys.stdout.buffer
+        else:
+            self.child.interact()
+        print('Session is returned, continue...')
+
+    def check_system_eeprom(self):
+        '''
+        - read system EEPROM
+            sys_eeprom onie --name product_name
+            sys_eeprom onie --name part_number
+            sys_eeprom onie --name serial_number
+        '''
+        # Read product name.
+        self.product_name = subprocess.check_output('sys_eeprom onie --name product_name'.split(), text=True).rstrip()
+
+        # Read part number.
+        self.part_number = subprocess.check_output('sys_eeprom onie --name part_number'.split(), text=True).rstrip()
+
+        # Read serial number.
+        self.serial_number = subprocess.check_output('sys_eeprom onie --name serial_number'.split(), text=True).rstrip()
+
+    def save_log(self, log):
+        # Set system datetime according to RTC time.
+        rtc_get = subprocess.check_output('rtc --get'.split(), text=True)
+        pattern = r'(?P<year>\d+)\/(?P<month>\d+)\/(?P<day>\d+)\s+\w+\s+(?P<time>\d+:\d+:\d+)'
+        match_datetime = re.findall(pattern, rtc_get)
+        for match_year, match_month, match_day, match_time in match_datetime:
+            rtc_datetime = f'{match_year}-{match_month}-{match_day} {match_time}'
+        subprocess.run(['date', '-s', rtc_datetime], stdout=subprocess.PIPE)
+
+        # Read system datetime.
+        current_time = datetime.now().strftime("%b-%d-%Y %H:%M:%S")
+
+        # Write system datetime.
+        log.write(f'Date: {current_time}\n')
+
+        # Write release version of image.
+        log.write(f'Version: {release_version}\n')
+
+        # Check result of test items.
+        for item in self.opdiag_toml['test_items']:
+            if item['name'] not in self.result_dic:
+                continue
+            # If there is a FAIL result in any of the test items, then the Summary result is FAIL.
+            if self.result_dic[item['name']] == FAIL:
+                summary = 'Summary: Diagnostics Fail\n'
+                break
+            else:
+                summary = 'Summary: Diagnostics Pass\n'
+        log.write(summary)
+
+        # Mode type: Normal and Extended.
+        # Write the mode type, and set the first letter of the mode to uppercase.
+        log.write(f'Mode: {mode.capitalize()}\n')
+        log.write('\n')
+
+        # Transfer product name and write system EEPROM.
+        trans_product_name = self.trans_product_name()
+        if trans_product_name is None:
+            log.write('\n')
+        else:
+            log.write(f'{trans_product_name}{":":<12s} {self.part_number} {self.serial_number}\n')
+
+        # Write title
+        log.write('\n')
+        log.write(f'{"Test":<28s} Result\n')
+        log.write(f'{"="*35}\n')
+
+        # Write test items and test results.
+        for item in self.opdiag_toml['test_items']:
+            if item['name'] not in self.result_dic:
+                continue
+            if self.result_dic[item['name']] == 'N/A':
+                self.result_dic[item['name']] = FAIL
+            log.write(f'{item["name"]:<28s} ')
+            log.write(f'{self.result_dic[item["name"]]}\n')
+
+        if self.verbose:
+            print('')
+            print('**********************************')
+            print('*** DEVELOPMENT MODE, SHOW LOG ***')
+            print('**********************************')
+            # Return the pointer to the beginning of the document.
+            log.seek(0)
+            print(log.read())
+            # Pause for 10 seconds to allow developers to review the log displayed.
+            time.sleep(10)
+
+    def rename_files(self, folder):
+        if folder.startswith('/'):
+            diagpart_path = folder
+        else:
+            diagpart_path = f'/{folder}'
+
+        tmp_path = f'/tmp{folder}'
+        os.makedirs(tmp_path, exist_ok=True)
+        filelist = []
+        for f_name in os.listdir(diagpart_path):
+            if re.match(r'operational-results-[0-9].txt', f_name):
+                filelist.append(f_name)
+                shutil.copy(f'{diagpart_path}/{f_name}', f'{tmp_path}/{f_name}')
+                os.remove(f'{diagpart_path}/{f_name}')
+        filelist = sorted(filelist)
+
+        if len(filelist) > 9:
+            for i in range(9, len(filelist)):
+                del filelist[i]
+
+        for i in range(len(filelist)):
+            new_log_name = f'operational-results-{i+1}.txt'
+            shutil.copy(f'{tmp_path}/{filelist[i]}', f'{diagpart_path}/{new_log_name}')
+
+    def get_display_mode(self):
+        if self.mode == 'normal':
+            return 'Normal mode'
+        elif self.mode == 'extended':
+            return 'Extended mode'
+        else:
+            return 'Unknown mode'
+
+    def verify_diagpart_mount(self):
+        try:
+            diagpart_check = subprocess.check_output('/alpha/bin/diagpart check'.split(), text=True)
+        except subprocess.CalledProcessError:
+            return False
+        if '/diagpart is not mounted' in diagpart_check:
+            subprocess.run('/alpha/bin/diagpart mount'.split())
+            return True
+        elif '/diagpart is mounted correctly' in diagpart_check:
+            return True
+        return False
+
+    def copy_log_to_diagpart(self):
+        folder_path = '/diagpart'
+        self.rename_files(folder_path)
+        shutil.copy('/tmp/operational-results-0.txt',
+                    '/diagpart/operational-results-0.txt')
+        # Unmount /diagpart before end of script.
+        subprocess.run('/alpha/bin/diagpart umount'.split())
+
+    # Function as the execution process of opdiag.
+    def run_opdiag(self):
+        if not self.verbose:
+            print('Initializing operational diagnostics...')
+            print(f'Version {release_version}, {release_date}')
+            print('')
+        else:
+            print('*****************************************************************')
+            print('*** DEVELOPMENT MODE, BEHAVIOR MIGHT DIFFER THAN FORMAL USAGE ***')
+            print('*****************************************************************')
+            self.child.logfile_read = sys.stdout.buffer
+
+        # Read System EEPROM
+        self.check_system_eeprom()
+
+        # Verify the mount status of the diagpart folder.
+        self.is_mounted = self.verify_diagpart_mount()
+
+        # DUT Init
+        self.dut_init()
+
+        # Check the type of test mode.
+        display_mode = self.get_display_mode()
+
+        if not self.verbose:
+            print(f'Running Power On Self Test...({display_mode})')
+        if display_mode == 'Unknown mode':
+            # The system will reboot if the mode is "unknown".
+            print('The diagnostics mode is invalid, the system will reboot!')
+            sys.exit(1)
+        print('')
+
+        # Run test items
+        for func_name in self.test_functions:
+            test_items = [item['name'] for item in self.opdiag_toml['test_items']]
+            if func_name not in test_items:
+                continue
+            else:
+                self.item_name = self.test_functions[func_name].__name__
+                flow_log_path = self.flow_log_path_from_toml.format(item_name=self.item_name)
+                if os.path.exists(flow_log_path):
+                    os.remove(flow_log_path)
+                self.test_functions[func_name]()
+            if self.result_dic[func_name] == FAIL and self.stop_if_fail:
+                self.interact()
+
+        # Start saving the log.
+        with open('/tmp/operational-results-0.txt', 'w+') as log:
+            self.save_log(log)
+
+        if no_exit:
+            self.interact()
+        else:
+            self.child.close()
+
+        print('')
+        print('Storing diagnostics result.')
+
+        # Rename files that already exist in /diagpart.
+        # Copy the log from /tmp to /diagpart and unmount /diagpart
+        if self.is_mounted:
+            self.copy_log_to_diagpart()
+        else:
+            print('Fail to store diagnostics result!')
+
+        print('Diagnostics completed.')
+        print('Waiting for reboot...')
+
+class AutoFlushFile:
+    def __init__(self, file):
+        self.file = file
+
+    def write(self, text):
+        # Write the text and flush the file
+        self.file.write(text)
+        self.file.flush()
+
+    def __getattr__(self, attr):
+        # Delegate other attributes/methods to the underlying file object
+        return getattr(self.file, attr)
+
+    def __enter__(self):
+        # If `__enter__` returns the object to be used in the `with` block, here we return self
+        return self
+
+    def __exit__(self, exc_type, exc_value, traceback):
+        # If `__exit__` returns True, it means exceptions that occur in the `with` block won't be propagated
+        return False
+
+class TestItemDecorator:
+    def __init__(self, log_file_required=False):
+        self.log_file_required = log_file_required
+    def __call__(self, func):
+        @wraps(func)
+        def wrapper(*args):
+            # args[0] contains the self parameter of the function in the class calling the decorator.
+            for item in args[0].opdiag_toml['test_items']:
+                if func.__name__ == item['name'].replace(" ", "_").lower():
+                    item_name = item['name']
+            if item_name not in args[0].test_functions:
+                return
+            if not args[0].verbose:
+                print(f'{item_name:<29s}', end='', flush=True)
+                args[0].check_dic.clear()
+                if not self.log_file_required:
+                    test_result = func(*args)
+                else:
