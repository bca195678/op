+        # Test item functions.
+        self.test_functions = {
+            'i2c environment': self.i2c_environment,
+            'internal flash': self.internal_flash,
+            'memory': self.memory,
+            'loopback mac interface': self.loopback_mac_interface,
+            'loopback phy copper': self.loopback_phy_copper,
+            'loopback phy fiber': self.loopback_phy_fiber,
+            'snake interface': self.snake_interface,
+            'PoE': self.poe,
+            'asic0 reg': self.asic0_reg,
+            'asic0 mem': self.asic0_mem
