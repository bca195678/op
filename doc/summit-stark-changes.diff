+    def pexpect_output(self, position):
+        try:
+            if position == 'after':
+                return self.child.after.decode('utf-8')
+            elif position == 'before':
+                return self.child.before.decode('utf-8')
+            else:
+                raise ValueError('position must be either "before" or "after"')
+        except AttributeError as err_msg:
+            if TIMEOUT in str(err_msg):
+                return '"TIMEOUT" due to not waiting for the expected output.'
+            return err_msg
+
+    def save_results(self, command, e_res, a_res, e_time):
+        if command and command[0] == '!': return
+        result = 'Success' if re.match(e_res, a_res) else 'Failure'
+        flow_log_path = self.flow_log_path_from_toml.format(item_name=self.item_name)
+        with open(flow_log_path, 'a+') as log:
+            content = log.readlines()
+            if command in content:
+                log.write(f'[{result}] retry {command} (Execution Time: {round(e_time, 3)}s)\n')
+            else:
+                log.write(f'[{result}] {command} (Execution Time: {round(e_time, 3)}s)\n')
+            log.write(f'    expected: {e_res}\n')
+            log.write(f'    actual:   {a_res}\n')
+
+    def send_command(self, command, pass_pattern=None, fail_pattern=None, timeout=10):
+        s_time = time.time()
+        if command == 'sh':
+            self.is_linux_prompt = True
+        elif command == 'exit':
+            self.is_linux_prompt = False
+        previous_logfile = self.child.logfile
+        self.child.logfile = None
+        self.child.sendline(command)
+        self.child.logfile = previous_logfile
+        pattern_list = []
+        if pass_pattern is None or pass_pattern == self.cli_prompt:
+            index = self.child.expect([self.cli_prompt, pexpect.TIMEOUT], timeout=timeout)
+            e_time = time.time() - s_time
+            self.save_results(command, self.cli_prompt, self.pexpect_output('after'), e_time)
+
+            return TIMEOUT if index != 0 else PASS
+        if pass_pattern == self.linux_prompt:
+            index = self.child.expect([self.linux_prompt, pexpect.TIMEOUT], timeout=timeout)
+            e_time = time.time() - s_time
+            self.save_results(command, self.linux_prompt, self.pexpect_output('after'), e_time)
+
+            return TIMEOUT if index != 0 else PASS
+
+        pattern_list = []
+        if type(fail_pattern) is str:
+            pattern_list.append(fail_pattern)
+        elif type(fail_pattern) is list:
+            for fail_pattern in fail_pattern:
+                pattern_list.append(fail_pattern)
+        pattern_list.append(pexpect.TIMEOUT)
+
+        pass_index = len(pattern_list)
+        timeout_index = pass_index - 1
+        if type(pass_pattern) is str:
+            pattern_list.append(pass_pattern)
+            index = self.child.expect(pattern_list, timeout=timeout)
+            if index == timeout_index:
+                result = TIMEOUT
+            elif index >= pass_index:
+                result = PASS
+            else:
+                result = FAIL
+            e_time = time.time() - s_time
+            self.save_results(command, pass_pattern, self.pexpect_output('after'), e_time)
+        elif type(pass_pattern) is list:
+            for pass_pattern in pass_pattern:
+                pattern_list.append(pass_pattern)
+            index = self.child.expect(pattern_list, timeout=timeout)
+            if index == timeout_index:
+                result = TIMEOUT
+            elif index >= pass_index:
+                result = PASS
+            else:
+                result = FAIL
+            e_time = time.time() - s_time
+            self.save_results(command, pass_pattern, self.pexpect_output('after'), e_time)
+
+        if not self.is_linux_prompt:
+            self.child.expect([self.cli_prompt, pexpect.TIMEOUT], timeout=timeout)
+        else:
+            self.child.expect([self.linux_prompt, pexpect.TIMEOUT], timeout=timeout)
+
+        return result
