+#!/bin/sh
+
+KICK_PERIOD=10
+PIDFILE=/tmp/pldwdtd.pid
+LOGFILE=/tmp/pldwdtd.log
+
+exec 2>&1 >>$LOGFILE
+
+kick()
+{
+    while true; do
+        uptime
+        ctrlplane watchdog --kick
+        sleep ${KICK_PERIOD}
+    done
+}
+
+cleanup()
+{
+    rm -f $PIDFILE
+    exit
+}
+
+[ -e $PIDFILE ] && exit 1
+
+trap cleanup EXIT
+
+if [ "`ctrlplane register --get WATCHDOG.ENABLE`" == "1" ]; then
+    echo "PLD Watchdog is enabled, keep kicking with period ${KICK_PERIOD} seconds"
+    echo $$ > $PIDFILE
+    kick
+else
+    echo "PLD Watchdog is disabled, skip it"
+fi
