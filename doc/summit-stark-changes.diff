+
+    # restore
+    set -- ${backup}
+
+    if [ -n "${OPDIAG_DEV}" ]; then
+        stty -F /dev/ttyS0 115200
+        exec </dev/ttyS0
+        exec >/dev/ttyS0
+        exec 2>/dev/ttyS0
+        reset
+        # Reset printk level
+        echo 7 4 1 7 > /proc/sys/kernel/printk
+    else
+        exec </dev/null
+        exec >/dev/null
+        exec 2>/dev/null
