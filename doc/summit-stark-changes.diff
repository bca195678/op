+#!/bin/sh
+
+# This script is designed for Fjord project to handle the diagnostics partition (/diagpart).
+# /diagpart will be used for "internal flash" test and log storage.
+
+set -o nounset
+# Uncomment to debug this script
+#set -o xtrace
+
+diagpart()
+{
+    set -- $(cat /proc/cmdline)
+    for x in "$@"; do
+        case "$x" in
+            diagnostics_partition=*)
+                local part="${x#diagnostics_partition=}"
+
+                # check if mountable
+                if [ -z "`blkid -s TYPE ${part}`" ]; then
+                    return 1
+                fi
+
+                echo "${part}"
+                return 0
+                ;;
+            *)
+                ;;
+        esac
+    done
+
+    return -1
+}
+
+# Try to (re)mount /diagpart
+mount_diagpart()
+{
+    local part="`diagpart`"
+
+    # Not available
+    if [ -z "${part}" ]; then
+        echo "diagnostics_partition is not available, skipped"
+        return 1
+    fi
+
+    umount_diagpart
+
+    if grep -q /diagpart /proc/self/mounts; then
+        echo "/diagpart is not clear, skipped"
+        return 1
+    fi
+    mkdir -p /diagpart
+    mount -o sync ${part} /diagpart
+
+    return 0
+}
+
+# Try to umount /diagpart or diagnostics_partition
+umount_diagpart()
+{
+    local part="`diagpart`"
+
+    if [ ! -z "${part}" ]; then
+        while grep -q ${part} /proc/self/mounts; do
+            umount ${part}
+        done
+    fi
+
+    if [ -d /diagpart ]; then
+        while grep -q /diagpart /proc/self/mounts; do
+            umount /diagpart
+        done
+
+        rm -r /diagpart
+    fi
+}
+
+usage()
+{
+    echo "usage: $(basename $0) [mount|umount|check|part]"
+}
+
+################
+# Main section #
+################
+
+if [ ! $# -eq 1 ]; then
+    usage
+    exit 0
+fi
+
+case "$1" in
+    mount)
+        mount_diagpart
+        exit $?
+        ;;
+    umount)
+        umount_diagpart
+        exit $?
+        ;;
+    check)
+        part="`diagpart`"
+        if [ -z "${part}" ]; then
+            echo "diagnostics_partition is not specified or not mountable"
+            exit 1
+        fi
+
+        mountcount=`grep /diagpart /proc/self/mounts | wc -l`
+        if [ ${mountcount} -eq 1 ] && grep -q ${part} /proc/self/mounts; then
+            echo "/diagpart is mounted correctly"
+        elif [ ${mountcount} -eq 0 ]; then
+            echo "/diagpart is not mounted"
+        elif [ ${mountcount} -gt 1 ]; then
+            echo "/diagpart is mounted by multiple partitions"
+        fi
+        ;;
+    part)
+        echo `diagpart`
+        ;;
+    *)
+        usage
+        ;;
+esac--- /dev/null
