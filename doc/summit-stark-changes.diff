+#!/bin/sh
+
+# Alphanetworks, Inc
+#
+# Script to invoke daemon to kick Extreme watchdog.
+
+case "$1" in
+  start)
+      start-stop-daemon -S -b -x /alpha/bin/pldwdtd
+      ;;
+  stop)
+      start-stop-daemon -K -n pldwdtd
+      ;;
+  *)
+      echo $"Usage: $0 {start|stop}"
+      exit 1
+esac
+
+exit $?
+
