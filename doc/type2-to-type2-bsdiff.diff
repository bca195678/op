diff --git a/rootfs.overlay/etc/init.d/S01boardid b/rootfs.overlay/etc/init.d/S01boardid
index 2b7be3177..35b37435b 100755
--- a/rootfs.overlay/etc/init.d/S01boardid
+++ b/rootfs.overlay/etc/init.d/S01boardid
@@ -20,7 +20,22 @@ echo "Board family: $FAMILY"

 case "$1" in
   start)
-  	start
+	start
+	# Reconstruct family-specific plugin from bsdiff patch
+	PLUGIN_DIR="/alpha/lib/module"
+	PATCH="${PLUGIN_DIR}/stark_to_fjord.patch"
+	STARK="${PLUGIN_DIR}/clish_plugin_mfg_stark.so"
+	FJORD="${PLUGIN_DIR}/clish_plugin_mfg_fjord.so"
+	if [ -f "${PATCH}" ]; then
+	    if [ "$FAMILY" = "fjord" ]; then
+	        echo "Reconstructing fjord plugin from patch..."
+	        /alpha/bin/bspatch "${STARK}" "${FJORD}" "${PATCH}"
+	        rm "${STARK}" "${PATCH}"
+	        echo "Fjord plugin ready"
+	    else
+	        rm "${PATCH}"
+	    fi
+	fi
 	;;
   stop)
 	;;
@@ -32,4 +47,3 @@ case "$1" in
 esac

 exit $?
